{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "gui-cnps-v2",
    "version": "0.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true,
        "setDecorations": true
        
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "Asteroidusv",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
      "windows": [{
                "label": "main",
                "fullscreen": false,
                "height": 370,
                "resizable": false,
                "title": "todo-app",
                "width": 435,
                "visible": true,
                "alwaysOnTop": true,
                "decorations": false,
                "transparent": true
            }],
      "macOSPrivateApi": true
    }
}

